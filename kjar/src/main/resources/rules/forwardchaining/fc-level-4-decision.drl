rule "Final decision HOLD FINE - cargo offload"
    salience 1
    when
        PermitStatus()
        not Violation(canContinue == false)
        exists Violation()
        exists Violation(type == ViolationType.TRAILER_OVERLOAD
                      || type == ViolationType.TOTAL_WEIGHT_OVERLOAD)
        $totalFine: Double() from accumulate(
            Violation($fine: fineAmount),
            sum($fine)
        )
        not FinalDecision()
    then
        FinalDecision decision = new FinalDecision();
        decision.setRecommendation(ActionRecommendation.HOLD_FINE);
        decision.setTotalFine($totalFine);
        decision.setRequiresDriverReplacement(false);
        decision.setRequiresCargoOffLoad(true);
        insert(decision);
end


rule "Final decision HOLD FINE - no offload"
    salience 1
    when
        PermitStatus()
        not Violation(canContinue == false)
        exists Violation()
        not Violation(type == ViolationType.TRAILER_OVERLOAD
                   || type == ViolationType.TOTAL_WEIGHT_OVERLOAD)
        $totalFine: Double() from accumulate(
            Violation($fine: fineAmount),
            sum($fine)
        )
        not FinalDecision()
    then
        FinalDecision decision = new FinalDecision();
        decision.setRecommendation(ActionRecommendation.HOLD_FINE);
        decision.setTotalFine($totalFine);
        decision.setRequiresDriverReplacement(false);
        decision.setRequiresCargoOffLoad(false);
        insert(decision);
end


rule "Final decision ALLOW"
    salience 1
    when
        PermitStatus()
        not Violation()
        not FinalDecision()
    then
        FinalDecision decision = new FinalDecision();
        decision.setRecommendation(ActionRecommendation.ALLOW);
        decision.setTotalFine(0.0);
        decision.setRequiresDriverReplacement(false);
        decision.setRequiresCargoOffLoad(false);
        insert(decision);
end