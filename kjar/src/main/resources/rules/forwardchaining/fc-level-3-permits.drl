package rules.forwardchaining;

import com.ftn.sbnz.model.models.Driver;
import com.ftn.sbnz.model.models.CMRDocument;
import com.ftn.sbnz.model.models.TransportPermit;
import com.ftn.sbnz.model.models.Violation;
import com.ftn.sbnz.model.models.VehicleValidity;
import com.ftn.sbnz.model.models.PermitStatus;
import com.ftn.sbnz.model.enums.ViolationType;
import com.ftn.sbnz.model.enums.ValidityStatus;
import com.ftn.sbnz.model.enums.TransportPermitType;

import java.time.LocalDate;


rule "Validate CEMT Permit"
    salience 100
    when
        VehicleValidity()
        TransportPermit(type == TransportPermitType.CEMT,
                        expiryDate != null,
                        expiryDate.isAfter(LocalDate.now()))
        not PermitStatus()
    then
        insert(new PermitStatus(ValidityStatus.VALID));
end


rule "Bilateral permit covers route"
    salience 90
    when
        VehicleValidity()
        not TransportPermit(type == TransportPermitType.CEMT,
                            expiryDate != null,
                            expiryDate.isAfter(LocalDate.now()))
        $driver: Driver($citizenship: citizenship)
        $cmr: CMRDocument($origin: originCountry, $destination: destinationCountry)
        TransportPermit(
            type == TransportPermitType.BILATERAL,
            expiryDate != null,
            expiryDate.isAfter(LocalDate.now()),
            coveredRoutes != null,
            $routes: coveredRoutes
        )
        eval(
            $routes.contains($citizenship) && $routes.contains($destination)
            && ($origin.equals($citizenship) || $origin.equals($destination))
        )
        not PermitStatus()
    then
        insert(new PermitStatus(ValidityStatus.VALID));
end


rule "Bilateral permit does not cover route"
    salience 89
    when
        VehicleValidity()
        not TransportPermit(type == TransportPermitType.CEMT,
                            expiryDate != null,
                            expiryDate.isAfter(LocalDate.now()))
        $driver: Driver($citizenship: citizenship)
        $cmr: CMRDocument($origin: originCountry, $destination: destinationCountry)
        TransportPermit(
            type == TransportPermitType.BILATERAL,
            expiryDate != null,
            expiryDate.isAfter(LocalDate.now()),
            coveredRoutes != null,
            $routes: coveredRoutes
        )
        eval(
            !($routes.contains($citizenship) && $routes.contains($destination)
              && ($origin.equals($citizenship) || $origin.equals($destination)))
        )
        not PermitStatus()
        not Violation(type == ViolationType.MISSING_THIRD_COUNTRY_PERMIT)
    then
        insert(new Violation(ViolationType.MISSING_THIRD_COUNTRY_PERMIT, "CEMT pravilnik, Čl. XXX", 100.0, false,
                             "Bilateralna dozvola ne pokriva robu iz treće zemlje. "
                             + "Zemlja porekla robe: " + $origin
                             + ", zemlja vozača: " + $citizenship
                             + ". Potrebna CEMT dozvola ili dozvola za treće zemlje."));
        insert(new PermitStatus(ValidityStatus.FORBIDDEN));
end


rule "Transit permit - vehicle passes through BiH"
    salience 80
    when
        VehicleValidity()
        not TransportPermit(type == TransportPermitType.CEMT,
                            expiryDate != null,
                            expiryDate.isAfter(LocalDate.now()))
        not TransportPermit(type == TransportPermitType.BILATERAL,
                            expiryDate != null,
                            expiryDate.isAfter(LocalDate.now()))
        $cmr: CMRDocument(destinationCountry != "BA")
        TransportPermit(type == TransportPermitType.TRANSIT,
                        expiryDate != null,
                        expiryDate.isAfter(LocalDate.now()))
        not PermitStatus()
    then
        insert(new PermitStatus(ValidityStatus.VALID));
end


rule "No valid route permit"
    salience 70
    when
        VehicleValidity()
        not TransportPermit(type == TransportPermitType.CEMT,
                                    expiryDate != null,
                                    expiryDate.isAfter(LocalDate.now()))
        not TransportPermit(type == TransportPermitType.BILATERAL,
                            expiryDate != null,
                            expiryDate.isAfter(LocalDate.now()))
        not TransportPermit(type == TransportPermitType.TRANSIT,
                            expiryDate != null,
                            expiryDate.isAfter(LocalDate.now()))
        not TransportPermit(type == TransportPermitType.THIRD_COUNTRY,
                            expiryDate != null,
                            expiryDate.isAfter(LocalDate.now()))
        not PermitStatus()
        not Violation(type == ViolationType.MISSING_THIRD_COUNTRY_PERMIT)
    then
        insert(new Violation(ViolationType.MISSING_THIRD_COUNTRY_PERMIT, "CEMT pravilnik, Čl. XXX", 100.0, false,
                            "Ne postoji nijedna validna dozvola za prevoz na ovoj ruti. Zabrana prelaska do otklanjanja nedostatka."));
        insert(new PermitStatus(ValidityStatus.FORBIDDEN));
end
